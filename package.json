    "verify:kie-payloads": "npx tsx scripts/verify-kie-model-payloads.ts",
    "verify:kie-general-models": "npx tsx scripts/verify-kie-general-models.ts",
    "verify:product-card-overlay": "npx tsx scripts/verify-product-card-overlay-strict.ts",
    "verify:dashboard-user-copy": "npx tsx scripts/verify-dashboard-user-copy.ts",
    "verify:telegram-auth": "npx tsx scripts/verify-telegram-auth.ts",
