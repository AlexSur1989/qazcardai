# Пример reverse proxy для VPS. Не подключайте этот файл напрямую в контейнер без правок.
#
# Подставьте свой сертификат (Let's Encrypt и т.д.) и имя сервера.
# Домен намеренно не зашит: используйте переменные окружения при генерации конфига
# или замените YOUR_HOSTNAME_HERE вручную.

upstream ai_media_upstream {
    # Вариант A: Nginx на хосте, приложение публикует порт на localhost
    server 127.0.0.1:3000;
    # Вариант B: Nginx в той же Docker-сети, что и compose (имя сервиса из docker-compose.yml)
    # server app:3000;
    keepalive 32;
}

server {
    listen 80;
    listen [::]:80;
    server_name YOUR_HOSTNAME_HERE;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name YOUR_HOSTNAME_HERE;

    # ssl_certificate     /etc/letsencrypt/live/YOUR_HOSTNAME_HERE/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/YOUR_HOSTNAME_HERE/privkey.pem;

    client_max_body_size 25m;

    # Дублирует/дополняет заголовки из Next.js (next.config.ts). HSTS — только если HTTPS настроен.
    add_header X-Frame-Options "DENY" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    location / {
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 300s;
        proxy_pass http://ai_media_upstream;
    }
}
